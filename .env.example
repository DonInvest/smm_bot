# AI для перевода и адаптации (можно использовать оба или один)
# Grok (xAI) - рекомендуется для X постов, лучше понимает алгоритм X
# Получить ключ: https://console.x.ai/ → API Keys (нужна подписка X Premium)
XAI_API_KEY=
# Gemini (Google) - альтернатива или для Farcaster
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# X (Twitter) — get via: python auth_x.py
X_USER_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/callback

# X OAuth 1.0a (optional, for media upload)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Farcaster (Neynar) — get signer via: python auth_farcaster.py
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=

# Imgbb для загрузки изображений в Farcaster (бесплатный API, получить ключ на https://api.imgbb.com)
IMGBB_API_KEY=

# Подсказки для @mention и $ticker (чтобы модель не угадывала, а подсвечивала проекты предсказуемо)
# Формат: "backpack:@Backpack:$BKP,katana:@Katana:$KAT"
PROJECT_ALIAS_HINTS=

# Стиль X через Grok: 1 = верный исходнику (без «вирусных» вопросов в конце), 0 = старый режим с упором на вопросы/engagement
X_FAITHFUL_X=1
# 1 = скрыть предпросмотр карточек у ссылок (tombstone), 0 = обычные ссылки с превью
X_SUPPRESS_LINK_PREVIEWS=0
# 1 = две подачи: отдельный EN для X и отдельный для Farcaster (один JSON от Grok/Gemini)
SEPARATE_X_FARCASTER=1
# Куда публиковать из КАНАЛА: 0 = выкл (только ручной пост в боте всё ещё в обе)
AUTOPOST_X=1
AUTOPOST_FARCASTER=1

# Автопостинг из Telegram-каналов (опционально)
# AUTOPOST_ENABLED=1 - включить автопостинг (1/true/yes/on)
# AUTOPOST_CHANNEL_IDS=-1001234567890,-1009876543210 - ID каналов через запятую (если пусто - все каналы)
# AUTOPOST_NOTIFY_CHAT_ID=123456789 - ID чата для уведомлений об автопостинге
# AUTOPOST_THREAD_MIN_BYTES=2000 - автотред только если текст длиннее N байт (уменьшает «левые» треды)
# AUTOPOST_DEDUPE_HOURS=0 - 0=выкл, иначе не постить тот же текст повторно в течение N часов
# GROK_REQUEST_TIMEOUT=90 - таймаут HTTP к api.x.ai (сек); при таймаутах увеличь до 120
# GROK_HTTP_ATTEMPTS=4 - число HTTP-попыток на один запрос к x.ai (таймаут/5xx/429)
# GROK_CIRCUIT_THRESHOLD=5 - подряд полных сбоев Grok до паузы (не DDOS API при длительном outage)
# GROK_CIRCUIT_SECONDS=120 - пауза без запросов к Grok; при GEMINI_API_KEY уйдёт в Gemini
# BOT_HEALTH_FILE=/tmp/smm_bot_health - опционально: раз в 60s пишется unix time (внешний watchdog)
AUTOPOST_ENABLED=
AUTOPOST_CHANNEL_IDS=
AUTOPOST_NOTIFY_CHAT_ID=
AUTOPOST_THREAD_MIN_BYTES=2000
AUTOPOST_DEDUPE_HOURS=0
GROK_REQUEST_TIMEOUT=90

# Optional
APP_ENV=development
LOG_LEVEL=INFO
