# Gemini (translation)
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# X (Twitter) — get via: python auth_x.py
X_USER_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/callback

# X OAuth 1.0a (optional, for media upload)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Farcaster (Neynar) — get signer via: python auth_farcaster.py
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=

# Imgbb для загрузки изображений в Farcaster (бесплатный API, получить ключ на https://api.imgbb.com)
IMGBB_API_KEY=

# Optional
APP_ENV=development
LOG_LEVEL=INFO
